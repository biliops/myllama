# ==========================================
# API 配置
# ==========================================
# Dify API Key
API_KEY=sk-h***K

# 本地推理服务的地址，例如 vLLM 通常是 http://localhost:8000/v1，Ollama 通常是 http://localhost:11434/v1
# Dify 的 OpenAI 兼容 API 端点格式为 http://hostname/v1
BASE_URL=http://llm.ai/v1

# 你本地已部署的模型名称
MODEL_ID=Qwen3.6:MTP

# Tavily 搜索引擎的API Key (需要去 https://tavily.com 免费注册获取)
TAVILY_API_KEY=tvly-3***1
